[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-e": "project_panel::Toggle",
      "ctrl-shift-a": "agent::Toggle",
      "ctrl-shift-q": "multi_workspace::ToggleWorkspaceSidebar",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-shift-e": "project_panel::Toggle",
      "ctrl-shift-a": "agent::Toggle",
      "ctrl-shift-q": "multi_workspace::ToggleWorkspaceSidebar",
    },
  },
]
